{
	"name": "rn_template",
	"version": "1.0.3",
	"private": true,
	"scripts": {
		"android": "react-native run-android --active-arch-only",
		"ios": "react-native run-ios",
		"lint": "biome lint --write && tsc --noEmit",
		"format": "biome format --write",
		"dev": "react-native start --reset-cache",
		"pod:i": "bunx pod-install ios",
		"pods:nuke": "cd ios && rm -rf Pods && rm -rf Podfile.lock && bundle exec pod install",
		"version:sync": "bun scripts/sync-version.mjs",
		"prerelease:ios": "bunx react-native run-ios --mode Release"
	},
	"dependencies": {
		"@hot-updater/bare": "0.25.7",
