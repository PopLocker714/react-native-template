		"@types/react": "^19.2.0",
		"babel-plugin-inline-import": "^3.0.0",
		"babel-plugin-module-resolver": "^5.0.2",
		"drizzle-kit": "^0.31.8",
		"hot-updater": "^0.25.7",
		"typescript": "^5.8.3"
