		"@op-engineering/op-sqlite": "^15.2.5",
		"@react-navigation/elements": "^2.9.10",
		"@react-navigation/native": "^7.1.33",
		"@react-navigation/native-stack": "^7.14.4",
		"dotenv": "^17.2.3",
		"drizzle-orm": "^0.45.1",
		"immer": "10.0.0",
		"matrix-js-sdk": "^41.0.0",
		"nanostores": "^1.1.0",
		"react": "19.2.3",
